# Copia este archivo como .env y llena los valores
PORT=4000
NODE_ENV=development

# Base de datos PostgreSQL (o Supabase connection string)
DATABASE_URL=postgresql://usuario:password@localhost:5432/alquiler_muebles

# JWT Secret (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_muy_segura_y_larga_123

# Email para notificaciones (Gmail, SendGrid, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_app_password
EMAIL_FROM=tu_empresa@gmail.com

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000
